<div class="slide-inner image-template">
	<div class="slide-image">
		#{self.section("body")}
	</div>
	<?r if self.section?("caption") ?>
		<div class="slide-caption">#{self.section("caption")}</div>
	<?r end ?>
	<?r if self.section?("translation") ?>
		<div class="slide-translation">
			#{self.section("translation")}
		</div>
	<?r end ?>
</div>
