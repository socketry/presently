<div class="slide-inner title-template">
	<div class="slide-title">
		#{self.section("title")}
	</div>
	<?r if self.section?("subtitle") ?>
		<div class="slide-subtitle">
			#{self.section("subtitle")}
		</div>
	<?r end ?>
	<?r if self.section?("translation") ?>
		<div class="slide-translation">
			#{self.section("translation")}
		</div>
	<?r end ?>
</div>
